{
  "name": "aether-browser",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --config electron-builder.local.yml",
    "release": "electron-builder --config electron-builder.release.yml --publish always",
    "gen:icons": "node scripts/gen-icons.js"
  },
  "build": {
    "appId": "com.aether.browser",
    "productName": "Aether Browser",
    "directories": {
      "buildResources": "build"
    },
    "icon": "build/favicon.ico",
    "win": {
      "target": "nsis",
      "icon": "build/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.0",
    "sharp": "^0.33.4"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
